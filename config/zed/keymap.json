[
  {
    "context": "Editor",
    "unbind": {
      "ctrl-h": "editor::Backspace",
      "ctrl-j": "editor::JoinLines",
      "ctrl-k": "editor::KillRingCut",
      "ctrl-l": "editor::ScrollCursorCenter",
      "ctrl-alt-left": "editor::MoveToPreviousSubwordStart",
      "ctrl-alt-right": "editor::MoveToNextSubwordEnd",
    },
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "ctrl-j": "vim::Down",
    },
  },
  {
    "context": "Editor && !VimControl",
    "unbind": {
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds",
    },
  },
  {
    "context": "VimControl",
    "bindings": {
      "q": null, //macros are lame
      "s": null, //never hit this on purpose (and it just behaves like insert mode???)
      "space": null, // stops zed from timing out when using 'leader' key space
      "alt-j": "editor::MoveLineDown",
      "alt-k": "editor::MoveLineUp",
      "ctrl-/": "editor::ToggleComments",
      "space g d": "editor::ToggleSelectedDiffHunks",
      "space g s": "git::ToggleStaged",
      "j": ["vim::Down", { "display_lines": true }],
      "k": ["vim::Up", { "display_lines": true }],
      "space f": "editor::Format",
      "space r n": "editor::Rename",
      "space g b": "editor::BlameHover",
      "space g B": "editor::OpenGitBlameCommit",
    },
  },
  {
    "context": "(Pane && !Editor) || VimControl",
    "bindings": {
      "space p a": "pane::CloseOtherItems",
      "space p p": "pane::TogglePinTab",
      "space p x": "pane::CloseActiveItem",
    },
  },
  {
    "context": "(Workspace && !Terminal && !Editor) || VimControl",
    "bindings": {
      "space": null, // stops zed from timing out when using 'leader' key space
      "space space": "tab_switcher::OpenInActivePane",
      "space s f": "file_finder::Toggle",
      "space s s": "project_symbols::Toggle",
      "space s g": "pane::DeploySearch",
      "space g g": "git_panel::ToggleFocus",
      "space t": "project_panel::ToggleFocus",
      "space s o": "projects::OpenRecent",
      "space o": "outline_panel::ToggleFocus",
    },
  },
  {
    "context": "Workspace && !Terminal",
    "bindings": {
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-L": "workspace::MovePaneRight",
      "ctrl-H": "workspace::MovePaneLeft",
      "ctrl-J": "workspace::MovePaneDown",
      "ctrl-K": "workspace::MovePaneUp",
    },
  },
  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "ctrl-j": "git_panel::FocusEditor",
    },
  },
  {
    "context": "GitPanel && CommitEditor",
    "bindings": {
      "ctrl-k": "git_panel::FocusChanges",
    },
  },
  {
    "context": "Dock && !Terminal && !Editor",
    "bindings": {
      "escape escape": "workspace::CloseActiveDock",
    },
  },
  {
    "context": "Editor && edit_prediction && edit_prediction_mode == eager && !showing_completions",
    "bindings": {
      "ctrl-y": "editor::AcceptEditPrediction",
    },
    "unbind": {
      "tab": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      "ctrl-y": "editor::AcceptEditPrediction",
    },
    "unbind": {
      "alt-tab": "editor::AcceptEditPrediction",
      "alt-l": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "Picker > Editor",
    "bindings": {
      "ctrl-y": "picker::ConfirmCompletion",
    },
    "unbind": {
      "tab": "picker::ConfirmCompletion",
    },
  },
  {
    "unbind": {
      "alt-enter": [
        "picker::ConfirmInput",
        {
          "secondary": false,
        },
      ],
      "ctrl-alt-enter": [
        "picker::ConfirmInput",
        {
          "secondary": true,
        },
      ],
    },
  },
  {
    "context": "Editor && showing_code_actions",
    "bindings": {
      "ctrl-y": "editor::ConfirmCodeAction",
    },
    "unbind": {
      "enter": "editor::ConfirmCodeAction",
    },
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "ctrl-shift-y": "editor::ConfirmCompletionReplace",
      "ctrl-l": "editor::ComposeCompletion",
      "ctrl-y": "editor::ConfirmCompletion",
    },
    "unbind": {
      "shift-enter": "editor::ConfirmCompletionReplace",
      "tab": "editor::ComposeCompletion",
      "enter": "editor::ConfirmCompletion",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "escape escape": "terminal_panel::ToggleFocus",
    },
    "unbind": {
      "ctrl-alt-left": "pane::SplitLeft",
      "ctrl-alt-right": "pane::SplitRight",
    },
  },
]
