[
  {
    "context": "Editor",
    "unbind": {
      "ctrl-h": "editor::Backspace",
      "ctrl-j": "editor::JoinLines",
      "ctrl-k": "editor::KillRingCut",
      "ctrl-l": "editor::ScrollCursorCenter",
      "ctrl-alt-left": "editor::MoveToPreviousSubwordStart",
      "ctrl-alt-right": "editor::MoveToNextSubwordEnd",
    },
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "ctrl-j": "vim::Down",
    },
  },
  {
    "context": "Editor && !VimControl",
    "unbind": {
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds",
    },
  },
  {
    "context": "VimControl",
    "bindings": {
      "q": null, //macros are lame
      "s": null, //never hit this on purpose (and it just behaves like insert mode???)
      "space": null, // stops zed from timing out when using 'leader' key space
      "alt-j": "editor::MoveLineDown",
      "alt-k": "editor::MoveLineUp",
      "ctrl-/": "editor::ToggleComments",
      "space g d": "editor::ToggleSelectedDiffHunks",
      "space g s": "git::ToggleStaged",
      "j": ["vim::Down", { "display_lines": true }],
      "k": ["vim::Up", { "display_lines": true }],
      "space f": "editor::Format",
      "space r n": "editor::Rename",
      "space g b": "editor::BlameHover",
      "space g B": "editor::OpenGitBlameCommit",
    },
  },
  {
    "context": "(Pane && !Editor && !Terminal) || VimControl",
    "bindings": {
      "space p a": "pane::CloseOtherItems",
      "space p p": "pane::TogglePinTab",
      "space p x": "pane::CloseActiveItem",
      "ctrl-right": "vim::ResizePaneRight",
      "ctrl-left": "vim::ResizePaneLeft",
      "ctrl-down": "vim::ResizePaneDown",
      "ctrl-up": "vim::ResizePaneUp",
    },
  },
  {
    "context": "(Workspace && !Terminal && !Editor) || VimControl",
    "bindings": {
      "space": null, // stops zed from timing out when using 'leader' key space
      "space space": "tab_switcher::OpenInActivePane",
      "space s f": "file_finder::Toggle",
      "space s s": "project_symbols::Toggle",
      "space s g": "pane::DeploySearch",
      "space g g": "git_panel::ToggleFocus",
      "space t": "project_panel::ToggleFocus",
      "space a o": "projects::OpenRecent",
      "space o": "outline_panel::ToggleFocus",
    },
  },
  {
    "context": "Workspace && !Terminal",
    "bindings": {
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-L": "workspace::MovePaneRight",
      "ctrl-H": "workspace::MovePaneLeft",
      "ctrl-J": "workspace::MovePaneDown",
      "ctrl-K": "workspace::MovePaneUp",
    },
  },
  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "ctrl-j": "git_panel::FocusEditor",
    },
  },
  {
    "context": "GitPanel && CommitEditor",
    "bindings": {
      "ctrl-k": "git_panel::FocusChanges",
    },
  },
  {
    "context": "Dock && !Terminal && !Editor",
    "bindings": {
      "escape escape": "workspace::CloseActiveDock",
    },
  },
  {
    "context": "Editor && edit_prediction && edit_prediction_mode == eager && !showing_completions",
    "bindings": {
      "ctrl-y": "editor::AcceptEditPrediction",
    },
    "unbind": {
      "tab": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      "ctrl-y": "editor::AcceptEditPrediction",
    },
    "unbind": {
      "alt-tab": "editor::AcceptEditPrediction",
      "alt-l": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "Picker > Editor",
    "bindings": {
      "ctrl-y": "picker::ConfirmCompletion",
    },
    "unbind": {
      "tab": "picker::ConfirmCompletion",
    },
  },
  {
    "unbind": {
      "alt-enter": [
        "picker::ConfirmInput",
        {
          "secondary": false,
        },
      ],
      "ctrl-alt-enter": [
        "picker::ConfirmInput",
        {
          "secondary": true,
        },
      ],
    },
  },
  {
    "context": "Editor && showing_code_actions",
    "bindings": {
      "ctrl-y": "editor::ConfirmCodeAction",
    },
    "unbind": {
      "enter": "editor::ConfirmCodeAction",
    },
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "ctrl-shift-y": "editor::ConfirmCompletionReplace",
      "ctrl-l": "editor::ComposeCompletion",
      "ctrl-y": "editor::ConfirmCompletion",
    },
    "unbind": {
      "shift-enter": "editor::ConfirmCompletionReplace",
      "tab": "editor::ComposeCompletion",
      "enter": "editor::ConfirmCompletion",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "escape escape": "terminal_panel::ToggleFocus",
    },
    "unbind": {
      "ctrl-alt-left": "pane::SplitLeft",
      "ctrl-alt-right": "pane::SplitRight",
    },
  },
  {
    "context": "Editor && in_snippet && has_next_tabstop && !showing_completions",
    "bindings": {
      "ctrl-l": "editor::NextSnippetTabstop",
    },
  },
  {
    "context": "Editor && in_snippet && has_next_tabstop && !showing_completions",
    "unbind": {
      "tab": "editor::NextSnippetTabstop",
    },
  },
  {
    "context": "Editor && in_snippet && has_previous_tabstop && !showing_completions",
    "bindings": {
      "ctrl-h": "editor::PreviousSnippetTabstop",
    },
  },
  {
    "context": "Editor && in_snippet && has_previous_tabstop && !showing_completions",
    "unbind": {
      "shift-tab": "editor::PreviousSnippetTabstop",
    },
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "ctrl-h": "buffer_search::DeployReplace",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-l": "editor::SelectLine",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-shift-j": "editor::JoinLines",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-shift-k": "editor::DeleteLine",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-shift-l": "editor::SelectAllMatches",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-1": ["workspace::ActivatePane", 0],
      "ctrl-2": ["workspace::ActivatePane", 1],
      "ctrl-3": ["workspace::ActivatePane", 2],
      "ctrl-4": ["workspace::ActivatePane", 3],
      "ctrl-5": ["workspace::ActivatePane", 4],
      "ctrl-6": ["workspace::ActivatePane", 5],
      "ctrl-7": ["workspace::ActivatePane", 6],
      "ctrl-8": ["workspace::ActivatePane", 7],
      "ctrl-9": ["workspace::ActivatePane", 8],
      "ctrl-0": ["workspace::ActivatePane", 9],
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "alt-1": ["workspace::ActivatePane", 0],
      "alt-2": ["workspace::ActivatePane", 1],
      "alt-3": ["workspace::ActivatePane", 2],
      "alt-4": ["workspace::ActivatePane", 3],
      "alt-5": ["workspace::ActivatePane", 4],
      "alt-6": ["workspace::ActivatePane", 5],
      "alt-7": ["workspace::ActivatePane", 6],
      "alt-8": ["workspace::ActivatePane", 7],
      "alt-9": ["workspace::ActivatePane", 8],
      "alt-0": ["workspace::ActivatePane", 9],
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-1": ["pane::ActivateItem", 0],
      "ctrl-2": ["pane::ActivateItem", 1],
      "ctrl-3": ["pane::ActivateItem", 2],
      "ctrl-4": ["pane::ActivateItem", 3],
      "ctrl-5": ["pane::ActivateItem", 4],
      "ctrl-6": ["pane::ActivateItem", 5],
      "ctrl-7": ["pane::ActivateItem", 6],
      "ctrl-8": ["pane::ActivateItem", 7],
      "ctrl-9": ["pane::ActivateItem", 8],
      "ctrl-0": ["pane::ActivateItem", 9],
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "alt-1": ["pane::ActivateItem", 0],
      "alt-2": ["pane::ActivateItem", 1],
      "alt-3": ["pane::ActivateItem", 2],
      "alt-4": ["pane::ActivateItem", 3],
      "alt-5": ["pane::ActivateItem", 4],
      "alt-6": ["pane::ActivateItem", 5],
      "alt-7": ["pane::ActivateItem", 6],
      "alt-8": ["pane::ActivateItem", 7],
      "alt-9": ["pane::ActivateItem", 8],
      "alt-0": ["pane::ActivateItem", 9],
    },
  },
  {
    "context": "RunModal",
    "bindings": {
      "ctrl-1": "new_process_modal::ActivateTaskTab",
      "ctrl-2": "new_process_modal::ActivateTaskTab",
      "ctrl-3": "new_process_modal::ActivateTaskTab",
      "ctrl-4": "new_process_modal::ActivateTaskTab",
      "ctrl-5": "new_process_modal::ActivateTaskTab",
      "ctrl-6": "new_process_modal::ActivateTaskTab",
      "ctrl-7": "new_process_modal::ActivateTaskTab",
      "ctrl-8": "new_process_modal::ActivateTaskTab",
      "ctrl-9": "new_process_modal::ActivateTaskTab",
      "ctrl-0": "new_process_modal::ActivateTaskTab",
    },
  },
  {
    "context": "RunModal",
    "unbind": {
      "alt-1": "new_process_modal::ActivateTaskTab",
      "alt-2": "new_process_modal::ActivateTaskTab",
      "alt-3": "new_process_modal::ActivateTaskTab",
      "alt-4": "new_process_modal::ActivateTaskTab",
      "alt-5": "new_process_modal::ActivateTaskTab",
      "alt-6": "new_process_modal::ActivateTaskTab",
      "alt-7": "new_process_modal::ActivateTaskTab",
      "alt-8": "new_process_modal::ActivateTaskTab",
      "alt-9": "new_process_modal::ActivateTaskTab",
      "alt-0": "new_process_modal::ActivateTaskTab",
    },
  },
  {
    "context": "GitPicker",
    "bindings": {
      "ctrl-1": "git_picker::ActivateBranchesTab",
      "ctrl-2": "git_picker::ActivateBranchesTab",
      "ctrl-3": "git_picker::ActivateBranchesTab",
      "ctrl-4": "git_picker::ActivateBranchesTab",
      "ctrl-5": "git_picker::ActivateBranchesTab",
      "ctrl-6": "git_picker::ActivateBranchesTab",
      "ctrl-7": "git_picker::ActivateBranchesTab",
      "ctrl-8": "git_picker::ActivateBranchesTab",
      "ctrl-9": "git_picker::ActivateBranchesTab",
      "ctrl-0": "git_picker::ActivateBranchesTab",
    },
  },
  {
    "context": "GitPicker",
    "unbind": {
      "alt-1": "git_picker::ActivateBranchesTab",
      "alt-2": "git_picker::ActivateBranchesTab",
      "alt-3": "git_picker::ActivateBranchesTab",
      "alt-4": "git_picker::ActivateBranchesTab",
      "alt-5": "git_picker::ActivateBranchesTab",
      "alt-6": "git_picker::ActivateBranchesTab",
      "alt-7": "git_picker::ActivateBranchesTab",
      "alt-8": "git_picker::ActivateBranchesTab",
      "alt-9": "git_picker::ActivateBranchesTab",
      "alt-0": "git_picker::ActivateBranchesTab",
    },
  },
]
